{
  "name": "pms-application",
  "version": "1.0.0",
  "description": "PMS Application",
  "main": "electron/dist/main.js",
  "scripts": {
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "build:electron": "tsup electron/main.ts electron/preload.ts --out-dir electron/dist --format cjs --external electron",
    "build:all": "npm run build:client && npm run build:server && npm run build:electron",
    "start": "npm run build:all && electron .",
    "pack": "npm run build:all && electron-builder --dir",
    "dist": "npm run build:all && electron-builder",
    "build:win": "npm run build:all && electron-builder --win --x64",
    "build:mac": "npm run build:all && electron-builder --mac",
    "test:electron": "vitest run --config electron/vitest.config.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "npm-run-all": "^4.1.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.payroll.system",
    "productName": "PMS Application",
    "icon": "client/public/icon",
    "asar": true,
    "extraResources": [
      {
        "from": "client/public/icon.png",
        "to": "icon.png"
      },
      {
        "from": "server/dist",
        "to": "server/dist"
      },
      {
        "from": "server/data",
        "to": "server/data"
      },
      {
        "from": "server/package.json",
        "to": "server/package.json"
      },
      {
        "from": "server/node_modules",
        "to": "server/node_modules"
      }
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "identity": null,
      "icon": "client/public/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "portable",
        "zip"
      ],
      "icon": "client/public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PMS Application",
      "installerIcon": "client/public/icon.ico",
      "uninstallerIcon": "client/public/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "client/public/icon.png"
    },
    "files": [
      "electron/dist/**/*",
      "client/dist/**/*",
      "client/public/icon.png"
    ]
  }
}
