  "name": "payroll-server",
  "version": "1.0.0",
  "description": "Payroll & User Management System - Backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "prisma generate && tsc",
